<%= form_with(model: [@museum, piece_collection], class: "row gx-3 gy-2 align-items-center") do |form| %>
  <% if piece_collection.errors.any? %>
    <div style="color: red">
      <h2><%= pluralize(piece_collection.errors.count, "error") %> prohibited this piece_collection from being
        saved:</h2>

      <ul>
        <% piece_collection.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="col-sm-8 mb-3">
    <%= form.label :name, class: "form-label" %>
    <%= form.text_field :name, class: "form-control", placeholder: "Nombre" %>
  </div>

  <div class="col-sm-8 mb-3">
    <%= form.label "Colección permanente?", class: "form-label" %>
    <%= form.label :is_permanent_true, 'Si', class: "form-label" %>
    <%= form.radio_button :is_permanent, true %>

    <%= form.label :is_permanent_false, 'No', class: "form-label" %>
    <%= form.radio_button :is_permanent, false %>
  </div>

  <div class="col-sm-8 ">
    <%= form.submit class: "btn btn-sm btn-outline-secondary" %>
  </div>
<% end %>